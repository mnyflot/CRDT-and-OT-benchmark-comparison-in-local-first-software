{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",             
    "moduleResolution": "NodeNext",   
    "types": ["node"],                
    "lib": ["esnext"],                
    
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  }
}